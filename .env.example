# Database (Postgres — use a Neon branch locally, full instance in production).
# Local dev: create a Neon dev branch and paste its pooled connection string.
# CI / Vercel: DATABASE_URL is injected by the Neon Vercel integration.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Separate Postgres DB for the test suite. Schema is wiped + re-pushed once
# per run by vitest.global-setup.ts. Create locally with:
#   createdb morning_form_test
# CI should point this at a disposable Postgres service.
TEST_DATABASE_URL="postgres://localhost:5432/morning_form_test"

# Public app origin used to build OAuth callback URLs.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Anthropic (LLM features — intake extraction, topic compilation, suggestions).
ANTHROPIC_API_KEY=""

# Auth (U0a + U0b). SESSION_SECRET hashes the magic-link tokens and signed
# session cookies — must be >=32 chars in production. Rotating it invalidates
# every live session and unconsumed magic link (global kill-switch).
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# Resend for magic-link email delivery. Use the EU region for UK-GDPR data
# residency. RESEND_FROM should be a verified domain address (e.g.
# hello@morningform.com) once DNS is set up; dev can use onboarding@resend.dev.
RESEND_API_KEY=""
RESEND_FROM="onboarding@resend.dev"

# Dev-only demo bypass. When set to "1", POSTing demo@morningform.com to
# /api/auth/request-link returns the raw verify URL in the response body so
# automated flows can skip the mailbox roundtrip. NEVER set in Vercel preview
# or production — it leaks Article 9 PII signals to any caller.
ALLOW_DEMO_BYPASS="1"

# Terra
# Used for Apple Health and Garmin via Terra's widget / webhook flow.
TERRA_API_KEY=""
TERRA_DEV_ID=""
TERRA_WEBHOOK_SECRET=""

# Whoop
# Callback: {NEXT_PUBLIC_APP_URL}/api/health/callback/whoop
WHOOP_CLIENT_ID=""
WHOOP_CLIENT_SECRET=""

# Oura
# Callback: {NEXT_PUBLIC_APP_URL}/api/health/callback/oura
OURA_CLIENT_ID=""
OURA_CLIENT_SECRET=""

# Fitbit
# Callback: {NEXT_PUBLIC_APP_URL}/api/health/callback/fitbit
FITBIT_CLIENT_ID=""
FITBIT_CLIENT_SECRET=""

# Garmin
# Garmin is currently routed through Terra in-app.
# These are reserved for a future direct Garmin implementation.
GARMIN_CONSUMER_KEY=""
GARMIN_CONSUMER_SECRET=""

# Google Fit
# Callback: {NEXT_PUBLIC_APP_URL}/api/health/callback/google_fit
GOOGLE_FIT_CLIENT_ID=""
GOOGLE_FIT_CLIENT_SECRET=""
