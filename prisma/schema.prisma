generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assessment       AssessmentResponse?
  stateProfile     StateProfile?
  protocol         Protocol?
  checkIns         CheckIn[]
  chatMessages     ChatMessage[]
  healthConnections HealthConnection[]
  healthDataPoints  HealthDataPoint[]
  suggestions      Suggestion[]
  preferences      UserPreferences?
  sourceDocuments  SourceDocument[]
  graphNodes       GraphNode[]
  graphEdges       GraphEdge[]
  topicPages       TopicPage[]
  graphMigratedAt  DateTime?
}

// ---------------------------------------------------------------------------
// Health Graph (pivot — see docs/plans/2026-04-15-004-feat-health-graph-pivot-plan.md)
// Three layers: SourceDocument/SourceChunk (raw, immutable) -> GraphNode/GraphEdge
// (compiled) -> TopicPage (rendered cache).
// ---------------------------------------------------------------------------

model SourceDocument {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  kind        String
  sourceRef   String?
  contentHash String?
  capturedAt  DateTime
  storagePath String?
  metadata    String?
  chunks      SourceChunk[]
  edges       GraphEdge[]   @relation("EdgeSourceDocument")
  createdAt   DateTime @default(now())

  @@unique([userId, contentHash])
  @@index([userId, kind])
  @@index([userId, capturedAt])
}

model SourceChunk {
  id               String   @id @default(cuid())
  sourceDocumentId String
  sourceDocument   SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  index            Int
  text             String
  offsetStart      Int
  offsetEnd        Int
  pageNumber       Int?
  metadata         String?
  edges            GraphEdge[] @relation("EdgeSourceChunk")
  createdAt        DateTime @default(now())

  @@unique([sourceDocumentId, index])
  @@index([sourceDocumentId])
}

model GraphNode {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  type          String
  canonicalKey  String
  displayName   String
  attributes    String?
  confidence    Float    @default(1.0)
  promoted      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  edgesOut      GraphEdge[] @relation("EdgeFromNode")
  edgesIn       GraphEdge[] @relation("EdgeToNode")

  @@unique([userId, type, canonicalKey])
  @@index([userId, type])
}

model GraphEdge {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  type             String
  fromNodeId       String
  fromNode         GraphNode @relation("EdgeFromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNodeId         String
  toNode           GraphNode @relation("EdgeToNode", fields: [toNodeId], references: [id], onDelete: Cascade)
  fromChunkId      String?
  fromChunk        SourceChunk? @relation("EdgeSourceChunk", fields: [fromChunkId], references: [id], onDelete: SetNull)
  fromDocumentId   String?
  fromDocument     SourceDocument? @relation("EdgeSourceDocument", fields: [fromDocumentId], references: [id], onDelete: SetNull)
  weight           Float    @default(1.0)
  metadata         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, type, fromNodeId, toNodeId, fromChunkId])
  @@index([userId, type])
  @@index([fromNodeId])
  @@index([toNodeId])
}

model TopicPage {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  topicKey            String
  status              String   @default("stub")
  rendered            String?
  graphRevisionHash   String?
  compileError        String?
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())

  @@unique([userId, topicKey])
  @@index([userId, status])
}

model AssessmentResponse {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  responses String
  completedAt DateTime @default(now())
  createdAt DateTime @default(now())
}

model StateProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  archetype         String
  primaryPattern    String
  patternDescription String
  observations      String
  constraints       String
  sensitivities     String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Protocol {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  version     Int      @default(1)
  status      String   @default("active")
  rationale   String
  confidence  String   @default("high")
  items       ProtocolItem[]
  adjustments ProtocolAdjustment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProtocolItem {
  id            String   @id @default(cuid())
  protocolId    String
  protocol      Protocol @relation(fields: [protocolId], references: [id])
  timeSlot      String
  timeLabel     String
  compounds     String
  dosage        String
  timingCue     String
  mechanism     String
  evidenceTier  String   @default("strong")
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
}

model ProtocolAdjustment {
  id          String   @id @default(cuid())
  protocolId  String
  protocol    Protocol @relation(fields: [protocolId], references: [id])
  description String
  rationale   String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  responses String
  date      String
  createdAt DateTime @default(now())

  @@index([userId, date])
  @@index([userId, type])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String
  content   String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model HealthConnection {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  provider     String
  status       String   @default("connected")
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  terraUserId  String?
  metadata     String?
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model HealthDataPoint {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  provider   String
  category   String
  metric     String
  value      Float
  unit       String
  timestamp  DateTime
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([userId, category, timestamp])
  @@index([userId, provider])
}

model RawProviderPayload {
  id         String   @id @default(cuid())
  userId     String
  provider   String
  source     String
  receivedAt DateTime @default(now())
  sizeBytes  Int
  payload    String
  traceId    String?

  @@index([userId, provider, receivedAt])
}

model Suggestion {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  date                DateTime
  kind                String
  title               String
  tier                String
  triggeringMetricIds String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, date, kind])
  @@index([userId, date])
}

model UserPreferences {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  wakeTime       String   @default("07:00")
  windDownTime   String   @default("22:00")
  timezone       String   @default("UTC")
  notifyMorning  Boolean  @default(true)
  notifyProtocol Boolean  @default(true)
  notifyEvening  Boolean  @default(true)
  notifyWeekly   Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
