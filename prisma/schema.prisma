generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // SEO/GEO funnel attribution — set on first signup only (never overwritten
  // on returning-user upserts). Drives anchor-page-to-signup funnel resolution
  // in src/lib/metrics/activation-funnel.ts.
  signupMarket String?
  signupCohort String?
  signupSlug   String?

  // LLM consent acceptance. Captured lazily at the moment of first LLM use
  // (chat, assessment, topic compile) via the 412 + modal flow — not eagerly
  // at signup. Null = not yet consented; LLM-bearing routes return 412 with
  // { requiresConsent: true } until the user accepts via POST /api/user/consent.
  // See docs/plans/2026-05-15-002-feat-lead-gen-signup-and-optional-assessment-plan.md.
  llmConsentAcceptedAt DateTime?

  assessment        AssessmentResponse?
  stateProfile      StateProfile?
  priorities        Priorities?
  checkIns          CheckIn[]
  chatMessages      ChatMessage[]
  healthConnections HealthConnection[]
  healthDataPoints  HealthDataPoint[]
  suggestions       Suggestion[]
  actions           Action[]
  bookingRequests   BookingRequest[]
  actionOutcomes    ActionOutcome[]
  draws             Draw[]
  preferences       UserPreferences?
  sourceDocuments   SourceDocument[]
  embeddingBackfills EmbeddingBackfillState[]
  graphNodes        GraphNode[]
  graphEdges        GraphEdge[]
  graphNodeLayouts  GraphNodeLayout[]
  topicPages        TopicPage[]
  sharedViews       SharedView[]
  graphMigratedAt   DateTime?

  magicLinkTokens MagicLinkToken[]
  sessions        Session[]

  scribes          Scribe[]
  scribeTopicLinks ScribeTopicLink[]
  scribeAudits     ScribeAudit[]

  // External MCP integration (Claude Desktop / Code / Codex). See
  // docs/plans/2026-05-12-002-feat-external-mcp-server-plan.md.
  mcpTokens      MCPToken[]
  mcpAuditEvents MCPAuditEvent[]

  // GDPR data rights. AccountDeletionTombstone deliberately has no relation
  // here — it must survive user.delete(). See
  // docs/plans/2026-06-04-001-feat-first-session-completeness-plan.md.
  exportRequests        ExportRequest[]
  accountDeletionTokens AccountDeletionToken[]
}

// ---------------------------------------------------------------------------
// SEO/GEO funnel measurement (U3 — see
// docs/plans/2026-05-09-001-feat-programmatic-seo-geo-plan.md). One row per
// first-paint of a marketing page; deduped within 1 minute via the
// (mfAnonymousId, slug, minuteBucket) unique constraint, NOT app-layer.
// `email` is backfilled at signup time so the funnel resolver can join
// LandingPageVisit -> User without a separate lookup table.
// ---------------------------------------------------------------------------
model LandingPageVisit {
  id             String   @id @default(cuid())
  slug           String
  cohortKey      String
  market         String
  referrer       String?
  ipHash         String
  mfAnonymousId  String
  // 'browser' | 'bot' | 'unknown' — kept as String so callers cannot drift
  // via literal-string typos (constants live in src/lib/marketing/constants.ts).
  userAgentClass String
  // Backfilled at signup-time (R14 of plan). NULL for visits that never sign up.
  email          String?  @db.VarChar(320)
  // Unix-epoch-minute, computed app-side. Composite unique key with slug +
  // mfAnonymousId enforces dedupe at the schema level (no app-layer race).
  minuteBucket   BigInt
  createdAt      DateTime @default(now())

  @@unique([mfAnonymousId, slug, minuteBucket])
  @@index([slug, market, createdAt])
  @@index([email])
}

// Activation funnel events. One row per meaningful step transition so we
// can compute drop-off rates between conceptual stages — landing,
// onboarding, assessment, reveal, sign-in, first-engagement. Distinct
// from LandingPageVisit (which is dedupe-per-minute and only covers
// marketing pages) and DiagnosticEvent (daily aggregate, no per-user
// path). Closes A7 of the activation audit (docs/strategy).
//
// `funnelId` is a client-generated stable id stored in localStorage —
// survives across pre-signin and post-signin so a user's full path
// stitches without requiring middleware-set cookies on every route.
//
// `properties` is intentionally Json — events have heterogeneous data
// (assessment_completed has questionCount + durationMs; sign_in_shown
// has nothing). Capped at 2KB at the API layer.
model FunnelEvent {
  id         String   @id @default(cuid())
  funnelId   String
  userId     String?
  event      String
  path       String?
  properties Json?
  createdAt  DateTime @default(now())

  @@index([funnelId, createdAt])
  @@index([userId, createdAt])
  @@index([event, createdAt])
}

// Single-table diagnostic counter with daily rotation. Each emit is an
// INSERT ... ON CONFLICT (key, day) DO UPDATE SET count = count + 1. Caps
// row growth at O(N_keys * N_days) — closes the silent-fallback DoS
// amplifier the predecessor plan would have had with one-row-per-emit.
model DiagnosticEvent {
  id         String   @id @default(cuid())
  key        String
  day        DateTime @db.Date
  count      Int      @default(1)
  lastSeenAt DateTime @default(now())

  @@unique([key, day])
  @@index([day])
}

// ---------------------------------------------------------------------------
// Auth (U0a + U0b — see docs/plans/2026-04-15-004-feat-health-graph-pivot-plan.md)
// MagicLinkToken issues the one-time code emailed to the user.
// MagicLinkRateLimit throttles request-link per email and per IP.
// Session backs the signed mf_session cookie.
// ---------------------------------------------------------------------------

model MagicLinkToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  consumedAt DateTime?

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model MagicLinkRateLimit {
  id          String   @id @default(cuid())
  // `subjectKind` = 'email-15m' | 'email-24h' | 'ip-1h' (the throttling window);
  // `subject` = lowercased email or ip-hash.
  subjectKind String
  subject     String
  window      DateTime
  count       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([subjectKind, subject, window])
  @@index([subjectKind, subject])
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  lastSeenAt DateTime  @default(now())
  userAgent  String?
  ipHash     String?

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Health Graph (pivot — see docs/plans/2026-04-15-004-feat-health-graph-pivot-plan.md)
// Three layers: SourceDocument/SourceChunk (raw, immutable) -> GraphNode/GraphEdge
// (compiled) -> TopicPage (rendered cache).
// ---------------------------------------------------------------------------

model SourceDocument {
  id          String                @id @default(cuid())
  userId      String
  user        User                  @relation(fields: [userId], references: [id])
  kind        String
  sourceRef   String?
  contentHash String?
  capturedAt  DateTime
  storagePath String?
  metadata    String?
  chunks      SourceChunk[]
  edges       GraphEdge[]           @relation("EdgeSourceDocument")
  aliases     SourceDocumentAlias[]
  // Retest loop (Plan 2026-06-17-001): the draw event this panel fulfils. Many
  // docs from one visit may attach to one draw (dedup); SetNull on draw erase.
  drawId      String?
  draw        Draw?                 @relation(fields: [drawId], references: [id], onDelete: SetNull)
  createdAt   DateTime              @default(now())

  @@unique([userId, contentHash])
  @@index([userId, kind])
  @@index([userId, capturedAt])
}

// T5 — cross-institution continuity. When the same clinical document arrives
// from two systems (e.g. a GP letter surfaced both via NHS App export and via
// Patients Know Best), `contentHash` dedup collapses them to one
// SourceDocument; the second import emits a SourceDocumentAlias so the audit
// trail of "which system showed us this, and when" survives.
model SourceDocumentAlias {
  id               String         @id @default(cuid())
  sourceDocumentId String
  sourceDocument   SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  system           String
  recordId         String?
  pulledAt         DateTime
  createdAt        DateTime       @default(now())

  @@unique([sourceDocumentId, system, recordId])
  @@index([sourceDocumentId])
}

model SourceChunk {
  id               String         @id @default(cuid())
  sourceDocumentId String
  sourceDocument   SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  index            Int
  text             String
  offsetStart      Int
  offsetEnd        Int
  pageNumber       Int?
  metadata         String?
  edges            GraphEdge[]    @relation("EdgeSourceChunk")
  embeddings       VectorEmbedding[]
  createdAt        DateTime       @default(now())

  @@unique([sourceDocumentId, index])
  @@index([sourceDocumentId])
}

model VectorEmbedding {
  id            String      @id @default(cuid())
  sourceChunkId String      @unique(map: "VectorEmbedding_sourceChunkId_key")
  sourceChunk   SourceChunk @relation(fields: [sourceChunkId], references: [id], onDelete: Cascade, map: "VectorEmbedding_sourceChunkId_fkey")
  model         String      // "openai/text-embedding-3-small" | "voyage-3" etc.
  dimensions    Int
  // Float[] chosen for immediate Prisma compatibility + testability (MVP).
  // Native pgvector (vector(1536)) + HNSW + <-> cosine operators enabled via ALTER in follow-up after PR 6 backfill.
  // MVP query arm uses JS-side cosine (or raw unnest math) on bounded candidates while Float[] (see Hybrid Query Path).
  vector        Float[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([sourceChunkId])
  @@index([model, createdAt])
}

model EmbeddingBackfillState {
  id                          String    @id @default(cuid())
  userId                      String?
  user                        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  model                       String
  status                      String    @default("running") // running | completed | failed
  dryRun                      Boolean   @default(false)
  estimateOnly                Boolean   @default(false)
  batchSize                   Int       @default(80)
  processedChunks             Int       @default(0)
  embeddedChunks              Int       @default(0)
  skippedChunks               Int       @default(0)
  totalTokens                 Int       @default(0)
  totalCostUsd                Float     @default(0)
  estimatedPendingChunks      Int       @default(0)
  estimatedPendingTokens      Int       @default(0)
  estimatedPendingCostUsd     Float     @default(0)
  lastProcessedChunkId        String?
  lastProcessedChunkCreatedAt DateTime?
  error                       String?
  startedAt                   DateTime  @default(now())
  completedAt                 DateTime?
  updatedAt                   DateTime  @updatedAt

  @@index([userId, model, status])
  @@index([updatedAt])
}

model GraphNode {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  type         String
  canonicalKey String
  displayName  String
  attributes   String?
  confidence   Float    @default(1.0)
  promoted     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  edgesOut GraphEdge[] @relation("EdgeFromNode")
  edgesIn  GraphEdge[] @relation("EdgeToNode")

  @@unique([userId, type, canonicalKey])
  @@index([userId, type])
}

model GraphEdge {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  type           String
  fromNodeId     String
  fromNode       GraphNode       @relation("EdgeFromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNodeId       String
  toNode         GraphNode       @relation("EdgeToNode", fields: [toNodeId], references: [id], onDelete: Cascade)
  fromChunkId    String?
  fromChunk      SourceChunk?    @relation("EdgeSourceChunk", fields: [fromChunkId], references: [id], onDelete: SetNull)
  fromDocumentId String?
  fromDocument   SourceDocument? @relation("EdgeSourceDocument", fields: [fromDocumentId], references: [id], onDelete: SetNull)
  weight         Float           @default(1.0)
  metadata       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([userId, type, fromNodeId, toNodeId, fromChunkId])
  @@index([userId, type])
  @@index([fromNodeId])
  @@index([toNodeId])
  // Panel diff joins observation instances to their lab document via
  // SUPPORTS(fromDocumentId) on every flag-on upload + /decisions render;
  // without this the [userId, type] index forces a scan across ALL of the
  // user's SUPPORTS edges (the highest-cardinality edge type).
  @@index([userId, fromDocumentId])
}

model TopicPage {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  topicKey          String
  status            String   @default("stub")
  rendered          String?
  graphRevisionHash String?
  compileError      String?
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@unique([userId, topicKey])
  @@index([userId, status])
}

// ---------------------------------------------------------------------------
// Desktop canvas layout persistence (U13) — per-node {x, y, pinned}.
// ---------------------------------------------------------------------------
model GraphNodeLayout {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodeId    String
  x         Float
  y         Float
  pinned    Boolean  @default(false)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userId, nodeId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Shareable views / DPP (U20). Signed-token share of a topic or graph view
// with optional redaction. tokenHash stores HMAC digest; scope describes what
// the share exposes (e.g., { kind: "topic", topicKey: "iron" }).
// ---------------------------------------------------------------------------
model SharedView {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique
  scope        String
  redactions   String?
  label        String?
  expiresAt    DateTime?
  revokedAt    DateTime?
  lastViewedAt DateTime?
  viewCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model AssessmentResponse {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  responses   String
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
}

model StateProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id])
  archetype          String
  primaryPattern     String
  patternDescription String
  observations       String
  constraints        String
  sensitivities      String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Priority markers — post-assessment deliverable. Pivots the previous-gen
// "supplement protocol" output (compounds + doses) to data-acquisition
// guidance (which biomarkers are worth measuring for the user's archetype).
// See docs/plans/2026-05-10-001-feat-priority-markers-pivot-plan.md.
// Same table shape as the deleted Protocol/ProtocolItem (per-user, versioned,
// rationale string, ordered items list) — only the field names + content
// change. Adjustments stay (same versioning concept survives the rename).
// ---------------------------------------------------------------------------
model Priorities {
  id          String                  @id @default(cuid())
  userId      String                  @unique
  user        User                    @relation(fields: [userId], references: [id])
  version     Int                     @default(1)
  status      String                  @default("active")
  rationale   String
  confidence  String                  @default("high")
  items       PriorityMarker[]
  adjustments PrioritiesAdjustment[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
}

model PriorityMarker {
  id                String     @id @default(cuid())
  prioritiesId      String
  priorities        Priorities @relation(fields: [prioritiesId], references: [id])
  // Marker name (e.g. "Ferritin", "Free testosterone", "ApoB"). NEVER a
  // compound or supplement name — the editorial-QA gate at
  // src/lib/compliance/static-copy.test.ts catches drift.
  markerName        String
  // One-sentence "why this matters for someone like you", tied to assessment
  // answers. Plain prose; no imperative-treatment language.
  rationale         String
  // Grouping tag (e.g. "iron", "hormones", "cardio"). Used for visual
  // grouping on the reveal page.
  category          String
  // Whether a typical UK or US private-blood-test panel includes the marker
  // out-of-the-box. One of: 'uk' | 'us' | 'both' | 'neither'. Helps the
  // visitor decide which provider to use.
  panelAvailability String     @default("both")
  sortOrder         Int        @default(0)
  createdAt         DateTime   @default(now())
}

model PrioritiesAdjustment {
  id           String     @id @default(cuid())
  prioritiesId String
  priorities   Priorities @relation(fields: [prioritiesId], references: [id])
  description  String
  rationale    String
  status       String     @default("pending")
  createdAt    DateTime   @default(now())
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  responses String
  date      String
  createdAt DateTime @default(now())

  @@unique([userId, date, type])
  @@index([userId, date])
  @@index([userId, type])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String
  content   String
  metadata  String?
  createdAt DateTime @default(now())
  actions   Action[]

  @@index([userId])
}

model HealthConnection {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  provider     String
  status       String    @default("connected")
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  terraUserId  String?
  metadata     String?
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model HealthDataPoint {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  provider  String
  category  String
  metric    String
  value     Float
  unit      String
  timestamp DateTime
  metadata  String?
  createdAt DateTime @default(now())

  @@index([userId, category, timestamp])
  @@index([userId, provider])
}

model RawProviderPayload {
  id         String   @id @default(cuid())
  // Nullable so GDPR erasure can scrub the owning userId to NULL (keeping the
  // raw diagnostic row for debugging without retaining the PII link).
  userId     String?
  provider   String
  source     String
  receivedAt DateTime @default(now())
  sizeBytes  Int
  payload    String
  traceId    String?

  @@index([userId, provider, receivedAt])
}

model Suggestion {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  date                DateTime
  kind                String
  title               String
  tier                String
  triggeringMetricIds String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, date, kind])
  @@index([userId, date])
}

model UserPreferences {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  wakeTime       String   @default("07:00")
  windDownTime   String   @default("22:00")
  timezone       String   @default("UTC")
  notifyMorning  Boolean  @default(true)
  notifyProtocol Boolean  @default(true)
  notifyEvening  Boolean  @default(true)
  notifyWeekly   Boolean  @default(true)
  // Retest-loop opt-in (Plan 2026-06-17-001). Honoured by the retest nudge cron.
  notifyRetest   Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Clinical scribes — specialist-GP agents bounded by per-topic scope-of-practice
// policy (see docs/plans/2026-04-18-001-feat-clinical-scribes-in-content-plan.md).
// One scribe per (userId, topicKey); enforced by ScribeTopicLink.
// ScribeAudit is append-only — idempotent upsert keyed by (scribeId, requestId).
// ---------------------------------------------------------------------------

model Scribe {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicKey     String
  systemPrompt String?
  // Default tracks DEFAULT_SCRIBE_MODEL in src/lib/scribe/repo.ts — the
  // schema-level default is reached by any prisma.scribe.create() that
  // omits `model`, independent of the TS constant. Keep them in sync.
  // Widens when multi-provider routing lands (see plan
  // docs/plans/2026-05-14-002-feat-multi-provider-scribe-routing-plan.md).
  model        String   @default("claude-sonnet-4-6")
  modelVersion String
  temperature  Float    @default(0.3)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tools     ScribeTool[]
  topicLink ScribeTopicLink?
  audits    ScribeAudit[]

  @@unique([userId, topicKey])
  @@index([userId])
}

model ScribeTool {
  id        String   @id @default(cuid())
  scribeId  String
  scribe    Scribe   @relation(fields: [scribeId], references: [id], onDelete: Cascade)
  toolName  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scribeId, toolName])
  @@index([scribeId])
}

model ScribeTopicLink {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicKey  String
  scribeId  String   @unique
  scribe    Scribe   @relation(fields: [scribeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, topicKey])
  @@index([userId])
}

model ScribeAudit {
  id                   String   @id @default(cuid())
  scribeId             String
  scribe               Scribe   @relation(fields: [scribeId], references: [id], onDelete: Cascade)
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicKey             String
  requestId            String
  mode                 String
  prompt               String
  toolCalls            String
  output               String
  citations            String
  safetyClassification String
  modelVersion         String
  // Set when this audit row was produced by a specialist invocation
  // chained from a parent scribe's `refer_to_specialist` tool call. The
  // value is the parent's `requestId`; null on top-level (general or
  // direct-routed) turns. Plan 2026-04-25-001 Unit 5 — see
  // `src/lib/scribe/tools/refer-to-specialist.ts`.
  parentRequestId      String?
  // Summed token usage across all tool-loop turns. Null when the client
  // provides no usage (legacy scripted test clients). Plan 2026-06-05-001
  // feat-ask-deep-phase-a Unit 1.
  inputTokens          Int?
  outputTokens         Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([scribeId, requestId])
  @@index([userId, topicKey])
  @@index([scribeId, createdAt])
  @@index([parentRequestId])
}

// ── External MCP integration ──
//
// MCPToken: bearer tokens issued by users from /settings/integrations/claude
// for external MCP clients (Claude Desktop, Claude Code, Codex, Cursor, VS
// Code MCP extension). Same HMAC+domain-separation pattern as Session and
// SharedView (see src/lib/share/tokens.ts), with the "mcp:" prefix.
//
// Lifecycle differs from SharedView: MCP tokens are long-lived programmatic
// credentials operating on the whole graph; share-view tokens are short-lived
// one-off reads of a single topic. Separating the tables keeps lifecycle
// queries (revocation sweeps, expiry batches) cheap on each.
//
// MCPAuditEvent: one row per external tool call. Separate from ScribeAudit
// so external-call traffic is queryable without joining against internal
// scribe runs.
model MCPToken {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String          @unique
  label       String
  expiresAt   DateTime?
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  useCount    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  auditEvents MCPAuditEvent[]

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model MCPAuditEvent {
  id           String   @id @default(cuid())
  tokenId      String
  token        MCPToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolName     String
  parameters   String // JSON-serialised tool arguments
  resultStatus String // 'success' | 'error' | 'rate_limited' | 'unauthorized'
  errorMessage String?
  latencyMs    Int
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([tokenId, createdAt])
}

// ---------------------------------------------------------------------------
// GDPR data rights — export + deletion
// (docs/plans/2026-06-04-001-feat-first-session-completeness-plan.md)
// ---------------------------------------------------------------------------

model ExportRequest {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 'pending' | 'complete' | 'failed'. Non-failed rows count toward the
  // 2-per-24h rate-limit window — a failed attempt never locks a user out
  // of an Article 15 right.
  status String @default("pending")

  // Blob pathname under uploads/<userId>/exports/. Non-null once
  // status='complete' — the account-deletion sweep reads these
  // pre-transaction to include export archives in the blob erasure.
  blobPath      String?
  failureReason String?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, createdAt])
}

model AccountDeletionToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  consumedAt DateTime?

  @@index([userId, createdAt])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Next-step actions — proposed by the scribe at the end of a substantive
// answer and persisted only when enforce() returns clinical-safe (Plan
// 2026-06-05-001 feat-ask-deep-phase-a Unit 5). Phase A: state only ever
// `suggested`. Not a Suggestion extension — lifecycle rows must not be
// delete-and-regenerated.
// ---------------------------------------------------------------------------
model Action {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatMessageId   String?
  // FK provenance to the assistant ChatMessage this action was proposed in.
  // onDelete: SetNull preserves the (append-only) Action row when its
  // ChatMessage is deleted outside account erasure, while enforcing
  // referential integrity at the DB level.
  chatMessage     ChatMessage? @relation(fields: [chatMessageId], references: [id], onDelete: SetNull)
  scribeRequestId String
  verb            String       // measure | discuss | track | behavior
  label           String
  markerName      String?
  state           String       @default("suggested") // Phase A: always 'suggested'
  // Lifecycle timestamps (Plan 2026-06-06-002 Phase B U2). Set on transition.
  acceptedAt      DateTime?
  completedAt     DateTime?
  dismissedAt     DateTime?
  createdAt       DateTime     @default(now())
  // Concierge booking requests linking this Action (SetNull on delete —
  // mirrors chatMessageId's pattern so the booking row survives Action removal).
  bookingRequests BookingRequest[]
  outcomes         ActionOutcome[]

  @@index([userId, createdAt])
  @@index([userId, state])
  @@index([scribeRequestId])
}

// ---------------------------------------------------------------------------
// Frozen outcome snapshot — written atomically with the outcome-measured
// transition (Plan 2026-06-06-002 Phase B U4). Captures the marker before/after
// at the moment the user closes the loop. Joins GDPR export + deletion +
// both structural-guard fixtures in the same unit (the vacuous-guard trap).
// ---------------------------------------------------------------------------
model ActionOutcome {
  id         String   @id @default(cuid())
  actionId   String   @unique // one outcome per action
  action     Action   @relation(fields: [actionId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  markerName String
  beforeValue Float?
  beforeAt    DateTime?
  afterValue  Float
  afterAt     DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([actionId])
}

// ---------------------------------------------------------------------------
// Concierge booking requests (Plan 2026-06-06-001 U3). One row per request.
// Marker names validated against canonical set at POST time. usState
// validated then DISCARDED (never persisted). markerNames nullified at
// terminal states per the retention schedule.
// ---------------------------------------------------------------------------
model BookingRequest {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  markerNames  String?   // JSON array, canonical-validated; nullified at terminal states
  market       String    // 'uk' | 'us'
  status       String    @default("requested") // requested|arranged|delivered|cancelled
  // Encrypted redemption code (AES-256-GCM via src/lib/health/crypto.ts —
  // single "<iv>:<tag>:<ciphertext>" hex string). Written at `deliver`;
  // nulled on the user's one-time in-app reveal. NEVER in email or logs.
  codeEncrypted String?
  actionId     String?   // FK to Action when linked (SetNull)
  action       Action?   @relation(fields: [actionId], references: [id], onDelete: SetNull)
  // Retest loop (Plan 2026-06-17-001): the draw event this booking intends to fulfil.
  drawId       String?
  draw         Draw?     @relation(fields: [drawId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, status, createdAt])
  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// Retest loop (Plan 2026-06-17-001). The Draw is the loop's heartbeat: one row
// per blood-draw / lab-panel event per user. It is simultaneously the retest
// record (retention-to-retest = >=2 completed draws), the cadence anchor (a
// scheduled draw carries scheduledFor + nudge bookkeeping), and the nudge
// target. Distinct from the 1:1 AssessmentResponse (a draw is a blood draw, not
// the onboarding questionnaire). No onDelete on userId — erased via the explicit
// ordered deleteMany in src/lib/account/delete.ts (audit-count discipline).
// ---------------------------------------------------------------------------
model Draw {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  // Per-user ordinal of COMPLETED draws (1 = baseline). Null while scheduled;
  // assigned at completion so cancelled/lapsed draws leave no gaps.
  sequence     Int?
  status       String    @default("scheduled") // scheduled | completed | cancelled | lapsed
  scheduledFor DateTime?
  completedAt  DateTime?
  // Nudge bookkeeping (the cron advances these): position in the nudge sequence
  // and when the last nudge was sent.
  nudgeCount   Int       @default(0)
  lastNudgedAt DateTime?
  lapsedAt     DateTime?
  // How a COMPLETED draw came about: baseline | nudge | organic | ops |
  // clinician | backfill. Drives nudge-attributed (loop-caused) retention.
  attribution  String?
  // A visit may yield several PDFs (dedup) → many docs attach to one draw.
  sourceDocuments SourceDocument[]
  // Booking attempts for this draw (a draw may be re-booked over its life).
  bookingRequests BookingRequest[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // The cron query: open scheduled draws due for a nudge. The global (all-users)
  // cron filters status + scheduledFor with no userId, so it needs a
  // userId-leading-free index; the userId-leading one serves per-user lookups.
  @@index([status, scheduledFor])
  @@index([userId, status, scheduledFor])
  // Unique completed ordinal per user (multiple NULLs allowed → many scheduled
  // draws coexist); the race guard for sequence assignment in U2.
  @@unique([userId, sequence])
}

// Survives account erasure by construction — NO User FK. The audit record
// that proves consent was held and erasure completed (UK GDPR Art. 5(2)),
// holding only non-re-identifying salted hashes.
model AccountDeletionTombstone {
  id String @id @default(cuid())

  // Salted one-way hash of the deleted account's email — duplicate-request
  // detection only.
  emailHash String

  // Salted hash of the confirming request's IP (existing ipHash convention);
  // abuse forensics, never the raw IP.
  ipHash String?

  // Snapshot of User.llmConsentAcceptedAt at erasure time.
  consentHeldAt DateTime?

  // 'pending' | 'completed'. Flips to completed as the LAST statement inside
  // the erasure $transaction so erasure + audit commit atomically.
  status String @default("pending")

  // JSON of per-domain deleted-row counts, recorded at completion.
  deletedCounts String?

  requestedAt DateTime  @default(now())
  confirmedAt DateTime?
  completedAt DateTime?

  @@index([emailHash])
}
